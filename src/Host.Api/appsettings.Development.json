{
    "ConnectionStrings":  {
                              "BusinessDb":  "Host=localhost;Port=5432;Database=enterprise_system_db;Username=postgres;Password=CHANGE_ME_BUSINESS_DB_PASSWORD",
                              "LogDb":  "Host=localhost;Port=5432;Database=enterprise_system_logdb;Username=postgres;Password=CHANGE_ME_LOG_DB_PASSWORD"
                          },
    "Serilog":  {
                    "Using":  [
                                  "Serilog.Sinks.File"
                              ],
                    "MinimumLevel":  {
                                         "Default":  "Information",
                                         "Override":  {
                                                          "Microsoft":  "Warning",
                                                          "Microsoft.AspNetCore":  "Warning"
                                                      }
                                     },
                    "Enrich":  [
                                   "FromLogContext"
                               ],
                    "WriteTo":  [
                                    {
                                        "Name":  "File",
                                        "Args":  {
                                                     "path":  "logs/dev-system-.txt",
                                                     "rollingInterval":  "Day",
                                                     "shared":  true,
                                                     "flushToDiskInterval":  "00:00:01",
                                                     "outputTemplate":  "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] ({CorrelationId}) {Message:lj}{NewLine}{Exception}"
                                                 }
                                    }
                                ]
                },
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "ExternalServices":  {
                             "ReferenceApi":  {
                                                  "BaseUrl":  "https://jsonplaceholder.typicode.com/",
                                                  "TimeoutSeconds":  5
                                              }
                         },
    "PasswordPolicy":  {
                           "MinLength":  12,
                           "RequireUppercase":  true,
                           "RequireLowercase":  true,
                           "RequireDigit":  true,
                           "RequireSpecialCharacter":  true,
                           "HistoryCount":  5,
                           "MinimumPasswordAgeMinutes":  5
                       },
    "BootstrapAdmin":  {
                           "UserCode":  "CORE_ADMIN",
                           "Username":  "core.admin",
                           "Email":  "core.admin@local",
                           "Password":  "CHANGE_ME_BOOTSTRAP_ADMIN_PASSWORD"
                       },
    "Observability":  {
                          "SensitiveDataLogging":  {
                                                       "RedactedHeaders":  [
                                                                               "Authorization",
                                                                               "Cookie",
                                                                               "Set-Cookie",
                                                                               "X-Api-Key"
                                                                           ],
                                                       "RedactedJsonFields":  [
                                                                                  "password",
                                                                                  "currentPassword",
                                                                                  "newPassword",
                                                                                  "refreshToken",
                                                                                  "accessToken",
                                                                                  "token",
                                                                                  "tokenHash",
                                                                                  "clientSecret",
                                                                                  "secret",
                                                                                  "signingKey"
                                                                              ],
                                                       "ExcludedPaths":  [
                                                                             "/api/auth/login",
                                                                             "/api/auth/refresh",
                                                                             "/api/auth/change-password"
                                                                         ],
                                                       "MaskValue":  "***REDACTED***"
                                                   }
                      },
    "Jwt":  {
                "Issuer":  "EnterpriseSystem",
                "Audience":  "EnterpriseSystem.Client",
                "SigningKey":  "DEV_ONLY_CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_32+_CHARS",
                "AccessTokenMinutes":  15,
                "RefreshTokenDays":  7
            }
}
