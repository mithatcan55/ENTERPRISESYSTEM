{
    "ConnectionStrings":  {
                              "BusinessDb":  "Host=localhost;Port=5432;Database=enterprise_system_db;Username=postgres;Password=CHANGE_ME_BUSINESS_DB_PASSWORD",
                              "LogDb":  "Host=localhost;Port=5432;Database=enterprise_system_logdb;Username=postgres;Password=CHANGE_ME_LOG_DB_PASSWORD"
                          },
    "Serilog":  {
                    "Using":  [
                                  "Serilog.Sinks.File"
                              ],
                    "MinimumLevel":  {
                                         "Default":  "Information",
                                         "Override":  {
                                                          "Microsoft":  "Warning",
                                                          "Microsoft.AspNetCore":  "Warning"
                                                      }
                                     },
                    "Enrich":  [
                                   "FromLogContext"
                               ],
                    "WriteTo":  [
                                    {
                                        "Name":  "File",
                                        "Args":  {
                                                     "path":  "logs/system-.txt",
                                                     "rollingInterval":  "Day",
                                                     "shared":  true,
                                                     "flushToDiskInterval":  "00:00:01",
                                                     "outputTemplate":  "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] ({CorrelationId}) {Message:lj}{NewLine}{Exception}"
                                                 }
                                    }
                                ]
                },
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "ExternalServices":  {
                             "ReferenceApi":  {
                                                  "BaseUrl":  "https://jsonplaceholder.typicode.com/",
                                                  "TimeoutSeconds":  5
                                              }
                         },
    "PasswordPolicy":  {
                           "MinLength":  12,
                           "RequireUppercase":  true,
                           "RequireLowercase":  true,
                           "RequireDigit":  true,
                           "RequireSpecialCharacter":  true,
                           "HistoryCount":  5,
                           "MinimumPasswordAgeMinutes":  5
                       },
    "BootstrapAdmin":  {
                           "UserCode":  "CORE_ADMIN",
                           "Username":  "core.admin",
                           "Email":  "core.admin@local",
                           "Password":  "CHANGE_ME_BOOTSTRAP_ADMIN_PASSWORD"
                       },
    "PersistenceBootstrap": {
      "EnableLegacyBusinessContextMigration": true
    },
    "Observability":  {
                          "SensitiveDataLogging":  {
                                                       "RedactedHeaders":  [
                                                                               "Authorization",
                                                                               "Cookie",
                                                                               "Set-Cookie",
                                                                               "X-Api-Key"
                                                                           ],
                                                       "RedactedJsonFields":  [
                                                                                  "password",
                                                                                  "currentPassword",
                                                                                  "newPassword",
                                                                                  "refreshToken",
                                                                                  "accessToken",
                                                                                  "token",
                                                                                  "tokenHash",
                                                                                  "clientSecret",
                                                                                  "secret",
                                                                                  "signingKey"
                                                                              ],
                                                       "ExcludedPaths":  [
                                                                             "/api/auth/login",
                                                                             "/api/auth/refresh",
                                                                             "/api/auth/change-password"
                                                                         ],
                                                       "MaskValue":  "***REDACTED***"
                                                   }
                          ,
                          "Routing": {
                            "DefaultPerformanceThresholdMs": 500,
                            "DisableAllNotifications": false,
                            "Routes": [
                              {
                                "EventName": "*",
                                "WriteSystemLog": true,
                                "WritePerformanceLog": false,
                                "WriteSecurityLog": false,
                                "SendNotification": false,
                                "NotificationChannels": [],
                                "MinimumSeverities": []
                              },
                              {
                                "EventName": "UnhandledExceptionOccurred",
                                "Category": "Error",
                                "WriteSystemLog": true,
                                "WritePerformanceLog": false,
                                "WriteSecurityLog": false,
                                "SendNotification": true,
                                "NotificationChannels": [ "email", "webhook" ],
                                "MinimumSeverities": [ "Error" ],
                                "OnlyFailures": true
                              },
                              {
                                "EventName": "TCodeAccessDenied",
                                "Category": "Authorization",
                                "WriteSystemLog": true,
                                "WritePerformanceLog": false,
                                "WriteSecurityLog": true,
                                "SendNotification": false,
                                "NotificationChannels": [],
                                "MinimumSeverities": [ "Warning" ],
                                "OnlyFailures": true
                              },
                              {
                                "EventName": "AuthLifecycleFailed",
                                "Source": "AuthLifecycleService",
                                "WriteSystemLog": true,
                                "WritePerformanceLog": false,
                                "WriteSecurityLog": true,
                                "SendNotification": false,
                                "NotificationChannels": [],
                                "MinimumSeverities": [ "Warning" ],
                                "OnlyFailures": true
                              },
                              {
                                "EventName": "BusinessOperationFailed",
                                "OperationName": "*",
                                "WriteSystemLog": true,
                                "WritePerformanceLog": true,
                                "WriteSecurityLog": false,
                                "SendNotification": false,
                                "NotificationChannels": [],
                                "MinimumSeverities": [ "Warning" ],
                                "OnlyFailures": true,
                                "PerformanceThresholdMs": 700
                              },
                              {
                                "EventName": "BusinessOperationCompleted",
                                "Category": "Operation",
                                "WriteSystemLog": true,
                                "WritePerformanceLog": true,
                                "WriteSecurityLog": false,
                                "SendNotification": false,
                                "NotificationChannels": [],
                                "MinimumSeverities": [ "Information" ],
                                "OnlySuccess": true,
                                "PerformanceThresholdMs": 700
                              },
                              {
                                "EventName": "*",
                                "MinimumHttpStatusCode": 500,
                                "WriteSystemLog": true,
                                "WritePerformanceLog": true,
                                "WriteSecurityLog": false,
                                "SendNotification": true,
                                "NotificationChannels": [ "email" ],
                                "MinimumSeverities": [ "Error" ],
                                "OnlyFailures": true
                              }
                            ]
                          },
                          "Notifications": {
                            "Email": {
                              "To": "ops@local"
                            },
                            "Webhook": {
                              "Url": ""
                            }
                          }
                      },
    "AllowedHosts":  "*",
    "Jwt":  {
                "Issuer":  "EnterpriseSystem",
                "Audience":  "EnterpriseSystem.Client",
                "SigningKey":  "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_32+_CHARS",
                "AccessTokenMinutes":  15,
                "RefreshTokenDays":  7
            }
}
