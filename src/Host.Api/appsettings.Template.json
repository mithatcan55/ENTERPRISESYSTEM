    "LogDb": "Host=localhost;Port=5432;Database=enterprise_system_logdb;Username=postgres;Password=CHANGE_ME_LOG_DB_PASSWORD"
  },
  "BootstrapAdmin": {
    "UserCode": "CORE_ADMIN",
    "Username": "core.admin",
